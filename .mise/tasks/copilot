#!/usr/bin/env bun
//MISE description="GitHub Copilot을 yolo 모드로 샌드박스 실행"
//MISE alias="p"

import { $ } from "bun";
import { c, launchAgent, parseArgs } from "./lib/shared.ts";

const { yoloboxFlags, toolArgs } = parseArgs(process.argv.slice(2));

const doctor = await $`mise run doctor`.nothrow();
if (doctor.exitCode !== 0) process.exit(doctor.exitCode ?? 1);
await Bun.sleep(1000);

console.log(`${c.green}${c.bold}✓ 검증 통과. Copilot 시작 중…${c.reset}\n`);
await launchAgent("copilot", toolArgs, yoloboxFlags);
