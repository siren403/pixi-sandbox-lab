#!/usr/bin/env bun
//MISE description="OpenCode를 yolo 모드로 샌드박스 실행"
//MISE alias="o"

import { $ } from "bun";
import { c, launchAgent } from "./lib/shared.ts";

const doctor = await $`mise run doctor`.nothrow();
if (doctor.exitCode !== 0) process.exit(doctor.exitCode ?? 1);
await Bun.sleep(1000);

console.log(`${c.green}${c.bold}✓ 검증 통과. OpenCode 시작 중…${c.reset}\n`);
await launchAgent("opencode");
